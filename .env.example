# ====================================================================
#  AI Interview Coach — Frontend Environment Variables
#  Copy this file to .env.local for local dev.
#  For Netlify, set NEXT_PUBLIC_API_URL in the Netlify dashboard.
# ====================================================================

# Local development
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Production (Netlify env var — set in dashboard, NOT in .env.local)
# NEXT_PUBLIC_API_URL=https://app.navin.lol/api
# NEXT_PUBLIC_ENABLE_SOCKET=false

# Optional: uncomment for production OG/Twitter image generation
# NEXT_PUBLIC_SITE_URL=https://interview-guide-ai.netlify.app
